# =============================================================================
# ADARSH WEB — ENVIRONMENT CONFIGURATION (TEMPLATE)
# =============================================================================
# Copy this file to '.env' and fill in the values for your environment.
# Values below are defaults or examples. DO NOT commit secrets to git.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. CORE DJANGO SETTINGS
# -----------------------------------------------------------------------------
# SECRET_KEY: Use a long, random string. Generate with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-change-me-in-production

# DEBUG: Set to False in production. Set to True only for local development.
DEBUG=False

# ALLOWED_HOSTS: Comma-separated list of hostnames this site can serve.
# Required in production. Include all domains and subdomains.
ALLOWED_HOSTS=adarshbhopal.in,www.adarshbhopal.in,panel.adarshbhopal.in

# TIME_ZONE: Project time zone.
TIME_ZONE=Asia/Kolkata

# INTERNAL_IPS: Comma-separated list of IPs allowed to see Debug Toolbar (if DEBUG=True).
INTERNAL_IPS=127.0.0.1,localhost

# -----------------------------------------------------------------------------
# 2. SUBDOMAIN ROUTING & URLs
# -----------------------------------------------------------------------------
# WEBSITE_DOMAIN: Public-facing website domain (e.g., www.example.com)
WEBSITE_DOMAIN=www.adarshbhopal.in

# PANEL_DOMAIN: Management panel domain (e.g., panel.example.com)
PANEL_DOMAIN=panel.adarshbhopal.in

# SITE_URL: Canonical base URL for the public website (used in emails).
SITE_URL=https://www.adarshbhopal.in

# -----------------------------------------------------------------------------
# 3. DATABASE SETTINGS
# -----------------------------------------------------------------------------
# DATABASE_URL: Standard connection string (PostgreSQL, MySQL, etc.)
# Format: postgres://user:password@host:5432/dbname
DATABASE_URL=postgres://user:password@localhost:5432/adarsh_db

# -----------------------------------------------------------------------------
# 4. REDIS & CACHING
# -----------------------------------------------------------------------------
# REDIS_URL: Connection string for Redis (required for caching/websockets).
# Format: redis://[[username]:password@]host[:port][/db]
REDIS_URL=redis://127.0.0.1:6379/1

# Optional individual components (if REDIS_URL is not provided):
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DB=1

# Cache tuning
# CACHE_DEFAULT_TIMEOUT=300
# CACHE_KEY_PREFIX=adarsh

# -----------------------------------------------------------------------------
# 5. DJANGO CHANNELS (REAL-TIME / WEBSOCKETS)
# -----------------------------------------------------------------------------
# Defaults to REDIS_URL if omitted.
# REDIS_CHANNEL_LAYER_URL=redis://127.0.0.1:6379/2
# REDIS_CHANNEL_PREFIX=adarsh:realtime

# -----------------------------------------------------------------------------
# 6. SECURITY & SSL
# -----------------------------------------------------------------------------
# SECURE_SSL_REDIRECT: Redirect all HTTP traffic to HTTPS.
SECURE_SSL_REDIRECT=True

# CSRF_TRUSTED_ORIGINS: Comma-separated list of origins trusted for CSRF.
CSRF_TRUSTED_ORIGINS=https://adarshbhopal.in,https://www.adarshbhopal.in,https://panel.adarshbhopal.in

# COOKIE DOMAINS: Set to parent domain (e.g., .example.com) to share sessions across subdomains.
# REQUIRED for subdomain routing to work seamlessly.
SESSION_COOKIE_DOMAIN=.adarshbhopal.in
CSRF_COOKIE_DOMAIN=.adarshbhopal.in

# SECURE_PROXY_SSL_HEADER_NAME: Header used by reverse proxy to signal HTTPS.
# Default: HTTP_X_FORWARDED_PROTO
# SECURE_PROXY_SSL_HEADER_NAME=HTTP_X_FORWARDED_PROTO
# SECURE_PROXY_SSL_HEADER_VALUE=https

# -----------------------------------------------------------------------------
# 7. EMAIL CONFIGURATION (SMTP)
# -----------------------------------------------------------------------------
EMAIL_HOST=mail.adarshbhopal.in
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@adarshbhopal.in
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL="Adarsh Admin <noreply@adarshbhopal.in>"

# Contact form submissions are sent TO this address:
CONTACT_FORM_RECIPIENT=hello@adarshbhopal.in

# -----------------------------------------------------------------------------
# 8. SENTRY (ERROR TRACKING)
# -----------------------------------------------------------------------------
# SENTRY_DSN: Leave blank to disable Sentry.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_PII=False

# -----------------------------------------------------------------------------
# 9. STATIC & MEDIA FILES
# -----------------------------------------------------------------------------
# MEDIA_USE_XACCEL: Set to True if using Nginx 'internal' location for media.
MEDIA_USE_XACCEL=False

# -----------------------------------------------------------------------------
# 10. PERFORMANCE & LOGGING
# -----------------------------------------------------------------------------
# LOG_TO_FILE: Write logs to 'logs/' directory on disk.
LOG_TO_FILE=False

# Slow request monitoring (seconds)
# SLOW_REQUEST_THRESHOLD=1.5
# SLOW_QUERY_THRESHOLD=0.1

# -----------------------------------------------------------------------------
# 11. GUNICORN (PRODUCTION SERVER)
# -----------------------------------------------------------------------------
# WEB_CONCURRENCY: Number of worker processes.
WEB_CONCURRENCY=2
# GUNICORN_WORKER_CLASS: Use 'uvicorn.workers.UvicornWorker' for Channels.
GUNICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker
GUNICORN_TIMEOUT=60
GUNICORN_BIND=unix:/run/gunicorn.sock

# -----------------------------------------------------------------------------
# 12. MOBILE & PWA SETTINGS
# -----------------------------------------------------------------------------
APP_VERSION=1.8.0
MOBILE_SHELL_ANDROID_MIN_BUILD=1
MOBILE_SHELL_ANDROID_LATEST_BUILD=1
MOBILE_SHELL_ANDROID_LATEST_VERSION=1.0.0
MOBILE_SHELL_ANDROID_FORCE_UPDATE=False
MOBILE_SHELL_ANDROID_UPDATE_URL=https://panel.adarshbhopal.in/static/website/apk/adarsh-admin.apk
MOBILE_SHELL_PRIVACY_URL=https://www.adarshbhopal.in/privacy/
MOBILE_SHELL_SUPPORT_URL=https://www.adarshbhopal.in/contact/

# -----------------------------------------------------------------------------
# 13. WEBSITE (LOCAL MODE)
# -----------------------------------------------------------------------------
# BRIDGE REMOVED - Application now uses local models for all content.
